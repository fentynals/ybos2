# Add these as GitHub repo secrets (Settings → Secrets and variables → Actions).
# Each platform is independent — set only the ones you've onboarded and the sync
# fills those, leaving the rest untouched. Never commit real values.

# --- YouTube (easiest: public stats, no OAuth) ---
YT_API_KEY=
YT_CHANNEL_ID=            # your channel id, starts with "UC..."

# --- TikTok (OAuth; needs a TikTok for Developers app with user.info.stats + video.list) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=     # from the one-time OAuth grant; the sync refreshes access tokens itself

# --- Instagram (Graph API; Business/Creator account + Meta app + long-lived token) ---
IG_TOKEN=                 # long-lived access token
IG_USER_ID=              # the IG Business account id (not your @handle)

# Local testing (optional): copy to tools/.env, fill in, then:
#   DRY_RUN=1 node --env-file=tools/.env tools/sync-analytics.mjs
